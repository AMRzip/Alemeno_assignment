{
  "info": {
    "_postman_id": "6bb9a64a-b41d-4a47-b7db-transaction-pipeline",
    "name": "AI-Powered Transaction Processing Pipeline",
    "description": "Postman collection for the Django REST API that uploads transaction CSV files, polls asynchronous jobs, and fetches processed transaction results.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                ""
              ]
            },
            "description": "Checks whether the API is running."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('API is healthy', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.have.property('status', 'ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Upload Transaction CSV",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "DevOps Assignment/transactions.csv"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/jobs/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "jobs",
                "upload"
              ]
            },
            "description": "Uploads a UTF-8 CSV file using multipart field `file`. On success, the response returns a `job_id`, which this request stores in the collection variable `jobId`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Upload accepted', function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Response contains job_id', function () {",
                  "    pm.expect(json).to.have.property('job_id');",
                  "});",
                  "",
                  "if (json.job_id) {",
                  "    pm.collectionVariables.set('jobId', json.job_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "jobs"
              ]
            },
            "description": "Lists all submitted processing jobs."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Jobs listed', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Jobs by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs?status={{jobStatus}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "jobs"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "{{jobStatus}}",
                  "description": "Filter jobs by status, for example pending, processing, completed, or failed."
                }
              ]
            },
            "description": "Lists jobs filtered by `status`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Filtered jobs listed', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Job Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/{{jobId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "jobs",
                "{{jobId}}",
                "status"
              ]
            },
            "description": "Fetches the current status for a submitted job. Run `Upload Transaction CSV` first to populate `jobId`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status fetched', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Response contains status', function () {",
                  "    pm.expect(json).to.have.property('status');",
                  "});",
                  "",
                  "if (json.status) {",
                  "    pm.collectionVariables.set('jobStatus', json.status);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Job Results",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/jobs/{{jobId}}/results",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "jobs",
                "{{jobId}}",
                "results"
              ]
            },
            "description": "Fetches full processed results for a completed job. If the job is still pending or processing, the API returns `409 Conflict`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Results fetched or still processing', function () {",
                  "    pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.test('Completed results include processed data', function () {",
                  "        pm.expect(json).to.have.property('cleaned_transactions');",
                  "        pm.expect(json).to.have.property('flagged_anomalies');",
                  "        pm.expect(json).to.have.property('category_spend_breakdown');",
                  "        pm.expect(json).to.have.property('llm_summary');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "jobId",
      "value": "",
      "type": "string"
    },
    {
      "key": "jobStatus",
      "value": "completed",
      "type": "string"
    }
  ]
}
